{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "rootDir": "..",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "tests/**/*", "../shared/**/*.ts"]
}