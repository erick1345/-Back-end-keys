{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    },
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true, // para não  utilizar any e unknown 
    "skipLibCheck": true
  },
  "include": ["src/**/*", "../shared/**/*.ts"]
}